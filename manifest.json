{
  "manifest_version": 3,
  "name": "ChatGPT Bulk Delete & Folders",
  "version": "1.0.0",
  "description": "Bulk delete, organize into folders, search, and export your ChatGPT conversations. 100% free. No data collected.",
  "minimum_chrome_version": "114",

  "permissions": ["storage", "cookies", "scripting"],
  "host_permissions": ["https://chatgpt.com/*"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "ChatGPT Bulk Delete & Folders",
    "default_icon": "icons/icone.png"
  },

  "icons": {
    "128": "icons/icone.png"
  },

  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
