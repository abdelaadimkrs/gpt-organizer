{
  "manifest_version": 3,
  "name": "GPT Organizer",
  "version": "1.0.0",
  "description": "Bulk delete, label, archive & export ChatGPT conversations. Folders, message navigator, notes & more. Free. No data collected.",
  "minimum_chrome_version": "114",

  "permissions": ["storage", "scripting"],
  "host_permissions": ["https://chatgpt.com/*"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "GPT Organizer",
    "default_icon": {
      "16":  "icons/16.png",
      "48":  "icons/48.png",
      "128": "icons/128.png"
    }
  },

  "icons": {
    "16":  "icons/16.png",
    "48":  "icons/48.png",
    "128": "icons/128.png"
  },

  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
